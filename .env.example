# API Key para Google Gemini
GOOGLE_API_KEY=tu_api_key_aqui_sin_comillas

# Si usas otro proveedor en el futuro, agrega aquí sus variables
# LLM_API_KEY=tu_api_key_aqui_sin_comillas

# Ruta para la persistencia de ChromaDB (Opcional)
CHROMA_DB_PATH=./db 
